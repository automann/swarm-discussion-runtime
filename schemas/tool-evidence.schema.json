{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automann.dev/swarm-discussion-runtime/schemas/tool-evidence.schema.json",
  "title": "Swarm Discussion Tool Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "agentId",
    "profileId",
    "tool",
    "artifactPath",
    "summary",
    "validated",
    "validation"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "swarm.tool_evidence"
    },
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "enum": ["read", "glob", "grep", "bash", "edit", "write"]
    },
    "artifactPath": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "validated": {
      "const": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ok", "validator"],
      "properties": {
        "ok": {
          "const": true
        },
        "validator": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
