{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automann.dev/swarm-discussion-runtime/schemas/runtime-contract.schema.json",
  "title": "Swarm Runtime Plugin Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "contractId",
    "runtime",
    "commands",
    "adapterFacingCommands",
    "integrationGates",
    "boundaries",
    "stableArtifacts",
    "forbiddenRuntimeResponsibilities"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "swarm.runtime_contract"
    },
    "contractId": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "required": ["name", "version", "compatibility"],
      "properties": {
        "name": {
          "const": "swarm-discussion-runtime"
        },
        "version": {
          "type": "string"
        },
        "compatibility": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["owner", "stability", "adapterFacing", "mutatesState", "responsibilities", "produces"],
        "properties": {
          "owner": {
            "const": "runtime"
          },
          "stability": {
            "const": "contract"
          },
          "adapterFacing": {
            "type": "boolean"
          },
          "mutatesState": {
            "type": "boolean"
          },
          "responsibilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "produces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "adapterFacingCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integrationGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundaries": {
      "type": "object",
      "required": ["skillPrompt", "hostAdapter", "runtime"],
      "additionalProperties": false,
      "properties": {
        "skillPrompt": {
          "$ref": "#/$defs/boundary"
        },
        "hostAdapter": {
          "$ref": "#/$defs/boundary"
        },
        "runtime": {
          "$ref": "#/$defs/boundary"
        }
      }
    },
    "stableArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "producer", "consumers"],
        "properties": {
          "path": {
            "type": "string"
          },
          "producer": {
            "type": "string"
          },
          "consumers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "forbiddenRuntimeResponsibilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "boundary": {
      "type": "object",
      "required": ["responsibilities", "forbidden"],
      "properties": {
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
