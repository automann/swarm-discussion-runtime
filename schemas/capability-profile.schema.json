{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automann.dev/swarm-discussion-runtime/schemas/capability-profile.schema.json",
  "title": "Swarm Discussion Capability Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "title",
    "role",
    "default",
    "status",
    "allowedTools",
    "toolEvidencePolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "swarm.capability_profile"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "enum": ["ordinary-expert", "expert", "coordinator", "executor"]
    },
    "default": {
      "type": "boolean"
    },
    "status": {
      "enum": ["active", "experimental", "research", "invalid-fixture"]
    },
    "allowedTools": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["read", "glob", "grep", "bash", "edit", "write"]
      }
    },
    "toolEvidencePolicy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["requiresLoggedToolCall", "requiresValidation", "citation"],
      "properties": {
        "requiresLoggedToolCall": {
          "const": true
        },
        "requiresValidation": {
          "const": true
        },
        "citation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
