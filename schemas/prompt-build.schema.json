{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Swarm Prompt Build Artifact",
  "type": "object",
  "required": [
    "schemaVersion",
    "phase",
    "topic",
    "prompt",
    "promptSha256",
    "visibility",
    "injectedIds",
    "inputs",
    "outputContract"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "declaration",
        "argumentation",
        "response",
        "moderator-opening",
        "contrarian",
        "cross-domain",
        "quality-gate"
      ]
    },
    "roundId": {
      "type": [
        "integer",
        "null"
      ]
    },
    "topic": {
      "type": "string"
    },
    "persona": {
      "type": "object"
    },
    "prompt": {
      "type": "string"
    },
    "promptSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "promptCharCount": {
      "type": "integer",
      "minimum": 0
    },
    "contextSummaryCharCount": {
      "type": "integer",
      "minimum": 0
    },
    "visibility": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": [
          "full",
          "gist"
        ]
      }
    },
    "injectedIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "messageCount",
        "contextSummarySha256",
        "visibilityBudget"
      ]
    },
    "outputContract": {
      "type": "object"
    }
  }
}
