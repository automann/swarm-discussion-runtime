{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automann.dev/swarm-discussion-runtime/schemas/host-transport.schema.json",
  "title": "Swarm Discussion Host Transport Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "host",
    "discussionId",
    "round",
    "phase",
    "parentContext",
    "runtimeCommands",
    "transport",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "host": {
      "enum": ["codex", "claude"]
    },
    "discussionId": {
      "type": "string",
      "minLength": 1
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "parentContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["briefPath", "phase", "agentIds", "nextHelperCommand"],
      "properties": {
        "briefPath": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "agentIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nextHelperCommand": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtimeCommands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contextBuild",
        "promptBuild",
        "collectMerge",
        "appendMessage",
        "checkpoint",
        "finalizeRound",
        "trace",
        "evidence"
      ],
      "properties": {
        "contextBuild": {
          "type": "string",
          "minLength": 1
        },
        "promptBuild": {
          "type": "string",
          "minLength": 1
        },
        "collectMerge": {
          "type": "string",
          "minLength": 1
        },
        "appendMessage": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint": {
          "type": "string",
          "minLength": 1
        },
        "finalizeRound": {
          "type": "string",
          "minLength": 1
        },
        "trace": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": true,
      "required": ["spawnPrimitive", "waitPrimitive", "resultKey"],
      "properties": {
        "spawnPrimitive": {
          "type": "string",
          "minLength": 1
        },
        "waitPrimitive": {
          "type": "string",
          "minLength": 1
        },
        "resultKey": {
          "enum": ["agent_id", "name"]
        },
        "partialBatches": {
          "type": "boolean"
        },
        "rawHostLogs": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "required": {
              "const": false
            }
          }
        },
        "customAgentProjection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["projected"],
          "properties": {
            "projected": { "type": "boolean" },
            "agentSourceDir": { "type": "string" },
            "count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true,
      "required": ["spawnOrderPath", "waitBatchesPath", "collectResultPath"],
      "properties": {
        "spawnOrderPath": {
          "type": "string",
          "minLength": 1
        },
        "waitBatchesPath": {
          "type": "string",
          "minLength": 1
        },
        "collectResultPath": {
          "type": "string",
          "minLength": 1
        },
        "hostStepPath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
